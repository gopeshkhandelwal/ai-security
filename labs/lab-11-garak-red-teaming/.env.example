# Garak Red Teaming Lab Configuration
# Copy this file to .env and fill in your values

# Target LLM Configuration
# -----------------------
# Generator type: openai, openrouter, huggingface, rest
TARGET_GENERATOR=openai

# Model identifier (depends on generator)
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# OpenRouter: openai/gpt-4, anthropic/claude-3-opus
# HuggingFace: meta-llama/Llama-2-7b-chat-hf
TARGET_MODEL=gpt-4

# API Keys
# --------
# OpenAI API Key
OPENAI_API_KEY=

# OpenRouter API Key (alternative to OpenAI)
OPENROUTER_API_KEY=

# HuggingFace Token (for gated models)
HUGGINGFACE_TOKEN=

# Custom REST API URL (for self-hosted models)
REST_API_URL=

# Scan Configuration
# ------------------
# Default scan profile: quick, standard, comprehensive
DEFAULT_SCAN_PROFILE=standard

# Report output directory
GARAK_REPORT_DIR=./reports

# Request rate limiting (seconds between requests)
REQUEST_DELAY=0.5

# Maximum probes per category (for faster scans)
MAX_PROBES_PER_CATEGORY=10
